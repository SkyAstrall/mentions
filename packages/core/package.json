			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown"
	},
	"keywords": [
		"mentions",
		"mention",
		"autocomplete",
		"autosuggest",
		"typeahead",
		"combobox",
		"trigger",
		"at-mention",
		"hashtag",
		"slash-commands",
		"textarea-autocomplete",
		"mention-input",
		"headless",
		"framework-agnostic",
		"vanilla-js",
		"input"
	]
