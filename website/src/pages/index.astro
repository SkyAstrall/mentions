---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import CopyInstall from "../components/CopyInstall.astro";
import CodeSnippet from "../components/CodeSnippet.astro";
import FeatureCard from "../components/FeatureCard.astro";
import HeroDemo from "../components/react/HeroDemo";
---

<BaseLayout title="@skyastrall/mentions — Multi-trigger inline suggestions for React">
	<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">Skip to content</a>

	<div class="relative overflow-hidden">
		<div class="absolute inset-0 pointer-events-none">
			<div class="bg-glow absolute top-[-200px] left-1/2 w-[1200px] h-[800px]" style="animation: bg-drift 8s ease-in-out infinite; will-change: transform, opacity; background: radial-gradient(ellipse 60% 40% at 50% 30%, rgba(139,47,201,0.06) 0%, rgba(139,47,201,0.02) 40%, transparent 70%);"></div>
		</div>

		<Nav />

		<section id="main" class="relative z-10 max-w-5xl mx-auto px-6 pt-24 sm:pt-32 pb-20 text-center" aria-labelledby="hero-heading">
			<div class="animate-enter" style="animation-delay: 0ms;">
				<span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-border text-xs font-medium text-text-secondary">
					<span class="w-1.5 h-1.5 rounded-full" style="background: #AB51E3; animation: pulse-dot 2s ease-in-out infinite; box-shadow: 0 0 8px rgba(171,81,227,0.5);" aria-hidden="true"></span>
					<a href="/docs/migration/v0-2-to-v0-3" class="hover:text-text transition-colors">v0.3.0 — Headless Architecture</a>
				</span>
			</div>

			<h1 id="hero-heading" class="animate-enter mt-8 mx-auto max-w-[680px]" style="animation-delay: 60ms; font-size: clamp(48px, 5.5vw, 72px); font-weight: 700; letter-spacing: -0.045em; line-height: 1.08;">
				Mentions that<br />
				<span class="hero-gradient">just work</span>
			</h1>

			<p class="animate-enter mt-6 mx-auto max-w-[540px] text-lg leading-relaxed text-text-secondary" style="animation-delay: 120ms; letter-spacing: -0.011em;">
				A headless React hook for inline suggestions.<br class="hidden sm:block" />
				@mentions, #tags, /commands — from one tiny primitive.
			</p>

			<div class="animate-enter mt-8 flex justify-center" style="animation-delay: 200ms;">
				<CopyInstall />
			</div>

			<div class="animate-enter mt-10" style="animation-delay: 280ms;">
				<HeroDemo client:load />
			</div>

			<div class="animate-enter mt-10 flex flex-wrap items-center justify-center gap-3" style="animation-delay: 340ms;">
				<a href="/docs" class="cta-primary">Get Started</a>
				<a href="https://github.com/SkyAstrall/mentions" target="_blank" rel="noopener" class="cta-ghost">
					View on GitHub
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline ml-1 -mt-0.5"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
				</a>
			</div>
		</section>

		<section class="relative z-10 max-w-3xl mx-auto px-6 pt-8 pb-24" aria-label="Code example">
			<CodeSnippet label="5 lines to get started" code={`import { Mentions } from "@skyastrall/mentions-react"

<Mentions
  triggers={[{ char: "@", data: users }]}
  onChange={(markup, plainText) => save(markup)}
/>`} />
		</section>

		<section class="relative z-10 max-w-[960px] mx-auto px-6 py-24" aria-label="Features">
			<span class="block text-[13px] font-medium uppercase tracking-[0.04em] text-text-dim mb-8">Features</span>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				<FeatureCard number="01" title="Multi-trigger" description="@ for users, # for tags, / for commands — each with its own data source, color, and config." />
				<FeatureCard number="02" title="Three API layers" description="Drop-in component, compound components, or headless hook. Pick your level of control." />
				<FeatureCard number="03" title="Ghost text" description="Dimmed inline AI completions. Tab to accept. Wire up any LLM in 5 lines of code." />
				<FeatureCard number="04" title="~14KB total gzipped" description="Core is ~8KB, React adapter is ~5KB. Zero runtime dependencies. No bloat." />
				<FeatureCard number="05" title="AI-ready" description="Async data with context — textBefore, textAfter, activeMentions. Built for LLM suggestions." />
				<FeatureCard number="06" title="Accessible" description="WAI-ARIA combobox pattern. Full keyboard navigation. Screen reader support." />
			</div>
		</section>

		<footer class="relative z-10 max-w-[960px] mx-auto px-6 py-6 border-t border-border">
			<div class="flex items-center justify-between text-[13px] text-text-dim">
				<span>Built by <a href="https://skyastrall.com" class="text-text-muted hover:text-text-secondary transition-colors">SkyAstrall</a></span>
				<div class="flex items-center gap-6">
					<span class="text-text-muted">v0.3.0</span>
					<a href="https://github.com/SkyAstrall/mentions" target="_blank" rel="noopener" class="hover:text-text-secondary transition-colors">GitHub</a>
					<a href="https://www.npmjs.com/package/@skyastrall/mentions-react" target="_blank" rel="noopener" class="hover:text-text-secondary transition-colors">npm</a>
				</div>
			</div>
		</footer>
	</div>
</BaseLayout>

<style>
	.cta-primary {
		display: inline-flex;
		align-items: center;
		padding: 10px 20px;
		font-size: 14px;
		font-weight: 500;
		letter-spacing: -0.006em;
		border-radius: 8px;
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1), filter 200ms ease;
	}

	.cta-primary:hover {
		transform: translateY(-1px);
		filter: brightness(0.9);
	}

	.cta-primary:active {
		transform: translateY(0);
		filter: brightness(0.85);
		transition-duration: 100ms;
	}

	.cta-ghost {
		display: inline-flex;
		align-items: center;
		padding: 10px 20px;
		font-size: 14px;
		font-weight: 500;
		letter-spacing: -0.006em;
		border-radius: 8px;
		border: 1px solid var(--color-border-hover);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
	}

	.cta-ghost:hover {
		border-color: rgb(255 255 255 / 0.2);
		color: var(--color-text);
		background: rgb(255 255 255 / 0.04);
	}

	.cta-ghost svg {
		transition: transform 150ms ease;
	}

	.cta-ghost:hover svg {
		transform: translate(2px, -2px);
	}

	.hero-gradient {
		background: linear-gradient(to right, #AB51E3, #DC97FF);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:global(html.light) .hero-gradient {
		background: linear-gradient(to right, #5A108F, #8B2FC9);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:global(html.light) .cta-ghost:hover {
		border-color: var(--color-border-hover);
		background: var(--color-bg-hover);
	}
</style>
