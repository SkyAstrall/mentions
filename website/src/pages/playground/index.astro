---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Playground from "../../components/react/Playground";
import VuePlayground from "../../components/vue/VuePlayground.vue";
import SveltePlayground from "../../components/svelte/SveltePlayground.svelte";
---

<BaseLayout title="Playground — @skyastrall/mentions">
	<div class="relative">
		<div class="absolute inset-0 pointer-events-none">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[radial-gradient(ellipse_at_center,rgba(99,102,241,0.06)_0%,transparent_70%)]"></div>
		</div>

		<Nav />

		<section class="relative z-10 max-w-6xl mx-auto px-6 pt-12 pb-24">
			<div class="mb-8">
				<h1 class="text-3xl font-bold tracking-tight mb-2">Playground</h1>
				<p class="text-text-secondary mb-5">Customize triggers, presets, and options. Copy the generated code.</p>

				<div class="pg-tabs" id="framework-tabs">
					<button type="button" class="pg-tab active" data-framework="react" aria-selected="true" role="tab">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="2.5"/><ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="currentColor" stroke-width="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(120 12 12)"/></svg>
						React
					</button>
					<button type="button" class="pg-tab" data-framework="vue" aria-selected="false" role="tab">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2 3h3.5L12 14.5 18.5 3H22L12 21 2 3z M7 3l5 8.5L17 3h-3l-2 3.5L10 3H7z"/></svg>
						Vue
					</button>
					<button type="button" class="pg-tab" data-framework="svelte" aria-selected="false" role="tab">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10.354 21.125a4.44 4.44 0 0 1-4.765-1.767 4.109 4.109 0 0 1-.703-3.107 3.898 3.898 0 0 1 .134-.522l.105-.321.287.21a7.21 7.21 0 0 0 2.186 1.092l.208.063-.02.208a1.253 1.253 0 0 0 .226.83 1.337 1.337 0 0 0 1.435.533 1.231 1.231 0 0 0 .343-.15l5.59-3.562a1.164 1.164 0 0 0 .524-.778 1.242 1.242 0 0 0-.211-.937 1.338 1.338 0 0 0-1.435-.533 1.23 1.23 0 0 0-.343.15l-2.133 1.36a4.078 4.078 0 0 1-1.135.499 4.44 4.44 0 0 1-4.765-1.766 4.108 4.108 0 0 1-.702-3.108 3.855 3.855 0 0 1 1.742-2.582l5.589-3.563a4.072 4.072 0 0 1 1.135-.499 4.44 4.44 0 0 1 4.765 1.767 4.109 4.109 0 0 1 .703 3.107 3.943 3.943 0 0 1-.134.522l-.105.321-.286-.21a7.204 7.204 0 0 0-2.187-1.093l-.208-.063.02-.207a1.255 1.255 0 0 0-.226-.831 1.337 1.337 0 0 0-1.435-.532 1.231 1.231 0 0 0-.343.15L8.62 9.368a1.162 1.162 0 0 0-.524.778 1.24 1.24 0 0 0 .211.937 1.338 1.338 0 0 0 1.435.533 1.235 1.235 0 0 0 .344-.151l2.132-1.36a4.067 4.067 0 0 1 1.135-.498 4.44 4.44 0 0 1 4.765 1.766 4.108 4.108 0 0 1 .702 3.108 3.857 3.857 0 0 1-1.742 2.583l-5.589 3.562a4.072 4.072 0 0 1-1.135.499"/></svg>
						Svelte
					</button>
					<div class="pg-indicator" id="pg-indicator" aria-hidden="true"></div>
				</div>
			</div>

			<div id="playground-react">
				<Playground client:load />
			</div>

			<div id="playground-vue" style="display: none;">
				<VuePlayground client:idle />
			</div>

			<div id="playground-svelte" style="display: none;">
				<SveltePlayground client:idle />
			</div>
		</section>
	</div>
</BaseLayout>

<script>
import { getFramework, setFramework, dispatchFwChange, onFwChange, updateSlidingIndicator } from "../../scripts/fw-sync";

function initPlaygroundTabs() {
	const container = document.getElementById("framework-tabs");
	const indicator = document.getElementById("pg-indicator");
	if (!container || !indicator) return;

	const tabs = container.querySelectorAll<HTMLButtonElement>(".pg-tab");

	function refreshIndicator() {
		const active = container!.querySelector<HTMLButtonElement>(".pg-tab.active");
		if (active) updateSlidingIndicator(container!, active, indicator!);
	}

	function switchTo(fw: string) {
		document.getElementById("playground-react")!.style.display = fw === "react" ? "block" : "none";
		document.getElementById("playground-vue")!.style.display = fw === "vue" ? "block" : "none";
		document.getElementById("playground-svelte")!.style.display = fw === "svelte" ? "block" : "none";
		tabs.forEach((btn) => {
			const isActive = btn.dataset.framework === fw;
			btn.classList.toggle("active", isActive);
			btn.setAttribute("aria-selected", isActive ? "true" : "false");
		});
		refreshIndicator();
		const qs = fw === "react" ? "" : `?fw=${fw}`;
		history.replaceState(null, "", `/playground/${qs}`);
	}

	tabs.forEach((tab) => {
		tab.addEventListener("click", () => {
			const fw = tab.dataset.framework!;
			switchTo(fw);
			setFramework(fw as "react" | "vue");
			dispatchFwChange(fw);
		});
	});

	onFwChange((fw) => {
		if (fw === "react" || fw === "vue" || fw === "svelte") {
			const current = container!.querySelector<HTMLButtonElement>(".pg-tab.active");
			if (current?.dataset.framework !== fw) switchTo(fw);
		}
	});

	const params = new URLSearchParams(window.location.search);
	const savedFw = params.get("fw") || getFramework();
	if (savedFw === "vue") switchTo("vue");
	if (savedFw === "svelte") switchTo("svelte");

	requestAnimationFrame(() => requestAnimationFrame(refreshIndicator));
	window.addEventListener("resize", refreshIndicator);
}

initPlaygroundTabs();
</script>

<style>
	.pg-tabs {
		position: relative;
		display: inline-flex;
		gap: 2px;
		padding: 3px;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 10px;
	}

	.pg-tab {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 7px 16px;
		font-size: 13px;
		font-weight: 500;
		color: var(--color-text-muted);
		background: transparent;
		border: none;
		border-radius: 7px;
		cursor: pointer;
		transition: color 150ms ease;
		letter-spacing: -0.01em;
	}

	.pg-tab:hover:not(.active) {
		color: var(--color-text-secondary);
	}

	.pg-tab.active {
		color: var(--color-text);
	}

	.pg-tab:active {
		transform: scale(0.96);
		transition-duration: 80ms;
	}

	.pg-tab svg {
		opacity: 0.7;
		transition: opacity 150ms ease;
	}

	.pg-tab.active svg {
		opacity: 1;
	}

	.pg-indicator {
		position: absolute;
		top: 3px;
		left: 3px;
		height: calc(100% - 6px);
		width: 0;
		background: var(--color-bg-elevated);
		border-radius: 7px;
		box-shadow: 0 1px 2px rgba(0,0,0,0.06);
		transition: transform 400ms var(--spring-bounce), width 400ms var(--spring-bounce);
		pointer-events: none;
	}
</style>
