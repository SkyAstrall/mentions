---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import Code from "../../../components/Code.astro";
---

<DocsLayout title="Compound Components">
	<p class="lead">Control layout while the library handles state, ARIA, and keyboard navigation.</p>

	<h2>Basic Structure</h2>
	<Code code={`import { Mentions } from "@skyastrall/mentions-react";

<Mentions triggers={triggers}>
  <Mentions.Editor placeholder="Type @..." className="my-editor" />
  <Mentions.Portal>
    <Mentions.List>
      <Mentions.Item />
    </Mentions.List>
  </Mentions.Portal>
</Mentions>`} />

	<h2>Custom Item Rendering</h2>
	<p>Use the <code>render</code> prop for full control over how items display.</p>
	<Code code={`<Mentions.Item render={({ item, highlighted }) => (
  <div style={{
    display: "flex",
    alignItems: "center",
    gap: 8,
    fontWeight: highlighted ? 600 : 400,
  }}>
    <img src={item.avatar} width={24} height={24} style={{ borderRadius: "50%" }} />
    <div>
      <div>{item.label}</div>
      <div style={{ fontSize: 12, opacity: 0.6 }}>{item.role}</div>
    </div>
  </div>
)} />`} />

	<h2>Manual Item Mapping</h2>
	<p>For full control over item iteration, pass <code>index</code> explicitly.</p>
	<Code code={`<Mentions triggers={triggers}>
  <Mentions.Editor />
  <Mentions.Portal>
    <Mentions.List>
      {items.map((item, i) => (
        <Mentions.Item key={item.id} index={i}>
          {item.label}
        </Mentions.Item>
      ))}
    </Mentions.List>
  </Mentions.Portal>
</Mentions>`} />

	<h2>Loading and Empty States</h2>
	<Code code={`<Mentions.List>
  <Mentions.Loading>
    <Spinner /> Searching...
  </Mentions.Loading>
  <Mentions.Empty>
    No results found
  </Mentions.Empty>
  <Mentions.Item render={({ item }) => item.label} />
</Mentions.List>`} />

	<h2>Portal Container</h2>
	<p>By default, the dropdown renders inline inside the component. To portal elsewhere:</p>
	<Code code={`<Mentions.Portal container={document.body}>
  <Mentions.List>...</Mentions.List>
</Mentions.Portal>`} />
</DocsLayout>
