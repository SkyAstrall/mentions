---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import CodeTabs from "../../../components/CodeTabs.astro";

---

<DocsLayout title="Compound Components">
	<p class="lead">Control layout while the library handles state, ARIA, and keyboard navigation.</p>

	<h2>Basic Structure</h2>
	<CodeTabs
		react={`import { Mentions } from "@skyastrall/mentions-react";

<Mentions triggers={triggers}>
  <Mentions.Editor placeholder="Type @..." className="my-editor" />
  <Mentions.Portal>
    <Mentions.List>
      <Mentions.Item />
    </Mentions.List>
  </Mentions.Portal>
</Mentions>`}
		vue={`<script setup>
import {
  Mentions, MentionsEditor, MentionsPortal,
  MentionsList, MentionsItem,
} from "@skyastrall/mentions-vue";
</script>

<template>
  <Mentions :triggers="triggers">
    <MentionsEditor placeholder="Type @..." class="my-editor" />
    <MentionsPortal>
      <MentionsList>
        <MentionsItem />
      </MentionsList>
    </MentionsPortal>
  </Mentions>
</template>`}
	/>

	<h2>Custom Item Rendering</h2>
	<CodeTabs
		react={`<Mentions.Item render={({ item, highlighted }) => (
  <div style={{
    display: "flex",
    alignItems: "center",
    gap: 8,
    fontWeight: highlighted ? 600 : 400,
  }}>
    <img src={item.avatar} width={24} height={24} style={{ borderRadius: "50%" }} />
    <div>
      <div>{item.label}</div>
      <div style={{ fontSize: 12, opacity: 0.6 }}>{item.role}</div>
    </div>
  </div>
)} />`}
		vue={`<MentionsItem v-slot="{ item, highlighted }">
  <div :style="{
    display: 'flex',
    alignItems: 'center',
    gap: '8px',
    fontWeight: highlighted ? 600 : 400,
  }">
    <img :src="item.avatar" width="24" height="24" style="border-radius: 50%" />
    <div>
      <div>{{ item.label }}</div>
      <div style="font-size: 12px; opacity: 0.6">{{ item.role }}</div>
    </div>
  </div>
</MentionsItem>`}
	/>

	<h2>Loading and Empty States</h2>
	<CodeTabs
		react={`<Mentions.List>
  <Mentions.Loading>
    <Spinner /> Searching...
  </Mentions.Loading>
  <Mentions.Empty>
    No results found
  </Mentions.Empty>
  <Mentions.Item render={({ item }) => item.label} />
</Mentions.List>`}
		vue={`<MentionsList>
  <MentionsLoading>
    <Spinner /> Searching...
  </MentionsLoading>
  <MentionsEmpty>
    No results found
  </MentionsEmpty>
  <MentionsItem />
</MentionsList>`}
	/>

	<h2>Portal Container</h2>
	<p>By default, the dropdown renders inline inside the component. To portal elsewhere:</p>
	<CodeTabs
		react={`<Mentions.Portal container={document.body}>
  <Mentions.List>...</Mentions.List>
</Mentions.Portal>`}
		vue={`<MentionsPortal to="body">
  <MentionsList>...</MentionsList>
</MentionsPortal>`}
	/>
</DocsLayout>
