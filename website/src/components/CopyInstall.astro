---
interface Props {
	command?: string;
}

const { command = "npm install @skyastrall/mentions-react" } = Astro.props;
---

<button class="install-bar" data-copy={command} type="button" aria-label={`Copy: ${command}`}>
	<span class="install-text">{command}</span>
	<span class="install-icon" aria-hidden="true">
		<svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
		</svg>
		<svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<polyline points="20 6 9 17 4 12"></polyline>
		</svg>
	</span>
</button>

<style>
	.install-bar {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 12px 16px;
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--color-text-secondary);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		cursor: pointer;
		transition: border-color 150ms ease, color 150ms ease;
	}

	.install-bar:hover {
		border-color: var(--color-border-hover);
		color: var(--color-text);
	}

	.install-icon {
		position: relative;
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	.icon-copy, .icon-check {
		position: absolute;
		inset: 0;
		transition: transform 150ms cubic-bezier(0.16, 1, 0.3, 1), opacity 100ms ease;
	}

	.icon-check {
		opacity: 0;
		transform: scale(0.8);
		color: #34d399;
	}

	.install-bar.copied .icon-copy {
		opacity: 0;
		transform: scale(0.8);
	}

	.install-bar.copied .icon-check {
		opacity: 1;
		transform: scale(1);
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>('.install-bar').forEach((btn) => {
		btn.addEventListener('click', () => {
			const cmd = btn.dataset.copy ?? '';
			navigator.clipboard.writeText(cmd).catch(() => {
				const ta = document.createElement('textarea');
				ta.value = cmd;
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
			});
			btn.classList.add('copied');
			btn.setAttribute('aria-label', 'Copied!');
			setTimeout(() => {
				btn.classList.remove('copied');
				btn.setAttribute('aria-label', `Copy: ${cmd}`);
			}, 2000);
		});
	});
</script>
