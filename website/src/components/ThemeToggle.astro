---

<button class="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
	<svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="12" cy="12" r="5"/>
		<line x1="12" y1="1" x2="12" y2="3"/>
		<line x1="12" y1="21" x2="12" y2="23"/>
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
		<line x1="1" y1="12" x2="3" y2="12"/>
		<line x1="21" y1="12" x2="23" y2="12"/>
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
	</svg>
	<svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
	</svg>
</button>

<style>
	.theme-toggle {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
		outline: none;
		transition: color 150ms ease, border-color 150ms ease, transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
	}

	.theme-toggle:hover {
		color: var(--color-text);
		border-color: var(--color-border-hover);
	}

	.theme-toggle:focus-visible {
		border-color: var(--color-accent);
	}

	.theme-toggle:active {
		transform: scale(0.92);
		transition-duration: 100ms;
	}

	.icon-sun, .icon-moon {
		position: absolute;
		transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease;
	}

	.icon-moon {
		opacity: 0;
		transform: rotate(-90deg) scale(0.5);
	}

	:global(html.light) .icon-sun {
		opacity: 0;
		transform: rotate(90deg) scale(0.5);
	}

	:global(html.light) .icon-moon {
		opacity: 1;
		transform: rotate(0deg) scale(1);
	}
</style>

<script>
	function getTheme(): 'light' | 'dark' {
		const stored = localStorage.getItem('theme');
		if (stored === 'light' || stored === 'dark') return stored;
		return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
	}

	function applyTheme(theme: 'light' | 'dark') {
		document.documentElement.classList.toggle('light', theme === 'light');
		localStorage.setItem('theme', theme);
	}

	applyTheme(getTheme());

	function initThemeToggles() {
		document.querySelectorAll('.theme-toggle').forEach((btn) => {
			if ((btn as HTMLElement).dataset.themeInit === '1') return;
			(btn as HTMLElement).dataset.themeInit = '1';

			btn.addEventListener('click', () => {
				const next = document.documentElement.classList.contains('light') ? 'dark' : 'light';
				document.documentElement.classList.add('theme-transitioning');
				applyTheme(next);
				requestAnimationFrame(() => {
					setTimeout(() => document.documentElement.classList.remove('theme-transitioning'), 500);
				});
			});
		});
	}

	initThemeToggles();

	document.addEventListener('astro:page-load', () => {
		applyTheme(getTheme());
		initThemeToggles();
	});

	document.addEventListener('astro:after-swap', () => {
		applyTheme(getTheme());
	});
</script>
