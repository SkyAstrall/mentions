---
interface Props {
	code: string;
	label?: string;
}

const { code, label } = Astro.props;
const trimmed = code.replace(/^\n/, "").replace(/\n$/, "");
---

<div class="snippet scroll-reveal">
	{label && <div class="snippet-header"><span>{label}</span></div>}
	<pre class="snippet-pre"><code set:text={trimmed} /></pre>
	<button class="snippet-copy" data-code={trimmed} type="button" aria-label="Copy code">
		<svg class="sc-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
		</svg>
		<svg class="sc-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<polyline points="20 6 9 17 4 12"></polyline>
		</svg>
	</button>
</div>

<style>
	.snippet {
		position: relative;
		border-radius: 12px;
		border: 1px solid var(--color-code-border);
		background: var(--color-code-bg);
		overflow: hidden;
	}

	.snippet-header {
		padding: 10px 16px;
		font-size: 12px;
		color: var(--color-text-dim);
		border-bottom: 1px solid var(--color-code-border);
	}

	.snippet-pre {
		margin: 0;
		padding: 20px;
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: 13px;
		line-height: 1.7;
		color: var(--color-code-text);
	}

	.snippet-copy {
		position: absolute;
		top: 12px;
		right: 12px;
		padding: 6px;
		background: var(--color-bg-hover);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		color: var(--color-text-muted);
		cursor: pointer;
		opacity: 0;
		transition: opacity 150ms ease, color 150ms ease, border-color 150ms ease;
	}

	.snippet:hover .snippet-copy {
		opacity: 1;
	}

	.snippet-copy:hover {
		color: var(--color-text);
		border-color: var(--color-border-hover);
	}

	.snippet-copy .sc-copy, .snippet-copy .sc-check {
		transition: transform 150ms cubic-bezier(0.16, 1, 0.3, 1), opacity 100ms ease;
	}

	.snippet-copy .sc-check {
		position: absolute;
		inset: 6px;
		opacity: 0;
		transform: scale(0.8);
		color: #34d399;
	}

	.snippet-copy.copied .sc-copy {
		opacity: 0;
		transform: scale(0.8);
	}

	.snippet-copy.copied .sc-check {
		opacity: 1;
		transform: scale(1);
	}
</style>

<script>
	import { initCopyButtons } from "../scripts/copy";
	initCopyButtons(".snippet-copy");
	document.addEventListener("astro:page-load", () => initCopyButtons(".snippet-copy"));
</script>
