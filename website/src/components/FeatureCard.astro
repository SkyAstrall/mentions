---
interface Props {
	number: string;
	title: string;
	description: string;
	class?: string;
}

const { number, title, description, class: className = "" } = Astro.props;
---

<div class:list={["feature-card scroll-reveal", className]}>
	<span class="feature-num">{number}</span>
	<h3 class="feature-title">{title}</h3>
	<p class="feature-desc">{description}</p>
</div>

<style>
	.feature-card {
		padding: 24px;
		border-radius: 12px;
		border: 1px solid var(--color-border);
		background: var(--color-bg-elevated);
		transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 200ms cubic-bezier(0.16, 1, 0.3, 1), background 200ms ease;
	}

	.feature-card:hover {
		transform: translateY(-2px);
		background: var(--color-bg-surface);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
	}

	.feature-card:active {
		transform: translateY(0);
		transition-duration: 100ms;
	}

	.feature-num {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-text-dim);
		letter-spacing: 0.02em;
	}

	.feature-title {
		font-size: 14px;
		font-weight: 500;
		letter-spacing: -0.006em;
		color: var(--color-text);
		margin: 8px 0;
	}

	.feature-desc {
		font-size: 14px;
		line-height: 1.6;
		letter-spacing: -0.006em;
		color: var(--color-text-muted);
		margin: 0;
	}
</style>
