---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import DocsSidebar from "../components/DocsSidebar.astro";

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={`${title} — @skyastrall/mentions`} description={description}>
	<Nav />

	<div class="docs-container">
		<DocsSidebar />
		<main class="docs-content">
			<h1>{title}</h1>
			<slot />
		</main>
	</div>

	<script>
		import { copyToClipboard } from "../scripts/copy";

		const FEEDBACK_MS = 2000;

		function initDocsCopyButtons() {
			document.querySelectorAll<HTMLPreElement>(".docs-content pre").forEach((pre) => {
				if (pre.parentElement?.classList.contains("code-block")) return;

				const wrapper = document.createElement("div");
				wrapper.className = "code-block";

				const btn = document.createElement("button");
				btn.className = "code-copy";
				btn.textContent = "Copy";
				btn.type = "button";
				btn.addEventListener("click", () => {
					const code = pre.querySelector("code")?.textContent ?? "";
					copyToClipboard(code);
					btn.textContent = "Copied!";
					setTimeout(() => { btn.textContent = "Copy"; }, FEEDBACK_MS);
				});

				pre.parentNode?.insertBefore(wrapper, pre);
				wrapper.appendChild(btn);
				wrapper.appendChild(pre);
			});
		}

		initDocsCopyButtons();
		document.addEventListener("astro:page-load", initDocsCopyButtons);
	</script>
</BaseLayout>

<style is:global>
	.docs-container {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 24px 80px;
		display: flex;
		gap: 48px;
	}

	.docs-content {
		flex: 1;
		min-width: 0;
		max-width: 720px;
	}

	.docs-content h1 {
		font-size: 2rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 8px;
	}

	.docs-content h2 {
		font-size: 1.35rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin: 48px 0 12px;
		padding-top: 24px;
		border-top: 1px solid var(--color-border);
	}

	.docs-content h2:first-of-type {
		border-top: none;
		padding-top: 0;
	}

	.docs-content h3 {
		font-size: 1.05rem;
		font-weight: 600;
		margin: 32px 0 8px;
	}

	.docs-content p {
		font-size: 15px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin: 0 0 16px;
	}

	.docs-content a {
		color: var(--color-accent);
		text-decoration: none;
	}

	.docs-content a:hover {
		text-decoration: underline;
	}

	.docs-content code:not(pre code) {
		font-family: var(--font-mono);
		font-size: 13px;
		padding: 2px 6px;
		border-radius: 4px;
		background: var(--color-bg-surface);
	}

	.docs-content ul, .docs-content ol {
		padding-left: 20px;
		margin: 0 0 16px;
	}

	.docs-content li {
		font-size: 15px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 4px;
	}

	.docs-content blockquote {
		margin: 16px 0;
		padding: 12px 16px;
		border-left: 3px solid var(--color-accent);
		background: var(--color-accent-muted);
		border-radius: 0 8px 8px 0;
	}

	.docs-content blockquote p {
		margin: 0;
		color: var(--color-text);
	}

	.code-block {
		position: relative;
		margin: 16px 0 24px;
	}

	.code-block pre {
		margin: 0;
		border-radius: 8px;
		border: 1px solid var(--color-border);
	}

	.code-copy {
		position: absolute;
		top: 8px;
		right: 8px;
		padding: 4px 10px;
		font-size: 11px;
		color: var(--color-text-muted);
		background: var(--color-bg-hover);
		border: 1px solid var(--color-border);
		border-radius: 4px;
		cursor: pointer;
		z-index: 1;
		transition: color 0.15s, border-color 0.15s;
	}

	.code-copy:hover {
		color: var(--color-text);
		border-color: var(--color-border-hover);
	}

	.docs-content .lead {
		font-size: 17px;
		color: var(--color-text-secondary);
		margin: 0 0 32px;
	}

	@media (max-width: 768px) {
		.docs-container {
			padding: 0 16px 60px;
		}

		.docs-content {
			max-width: 100%;
		}
	}
</style>
