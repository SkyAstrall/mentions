{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"includes": [
			"packages/**",
			"e2e/**",
			"!**/dist",
			"!**/node_modules",
			"!**/.svelte-kit",
			"!**/*.svelte"
		]
	},
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "error"
			}
		}
	},
	"javascript": {
		"jsxRuntime": "transparent"
	}
}
